{
  "name": "dutch-weather-intelligence",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && prisma migrate deploy && next build",
    "postbuild": "prisma db seed",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "ingest:weather": "tsx scripts/ingest.ts weather",
    "ingest:air-quality": "tsx scripts/ingest.ts air-quality",
    "ingest:water": "tsx scripts/ingest.ts water",
    "ingest:all": "tsx scripts/ingest.ts all --all",
    "dashboard:regenerate": "tsx scripts/ingest.ts dashboard"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "dotenv": "^17.2.1",
    "next": "^15.3.0",
    "prisma": "^6.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.4",
    "@types/node": "^22.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.30.0",
    "eslint-config-next": "^15.3.0",
    "tailwindcss": "^4.1.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
