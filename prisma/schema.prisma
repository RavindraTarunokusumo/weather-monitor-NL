generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model City {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  name        String
  countryCode String   @default("NL")
  latitude    Float
  longitude   Float
  timezone    String   @default("Europe/Amsterdam")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  weatherSnapshots    WeatherSnapshot[]
  airQualitySnapshots AirQualitySnapshot[]
  waterSnapshots      WaterSnapshot[]
  dashboardSnapshots  DashboardSnapshot[]
}

model SourceRun {
  id             String    @id @default(uuid()) @db.Uuid
  sourceName     String
  jobType        String
  status         String
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  recordsFetched Int       @default(0)
  recordsStored  Int       @default(0)
  errorMessage   String?
  metadata       Json?
}

model WeatherSnapshot {
  id              String   @id @default(uuid()) @db.Uuid
  cityId          String   @db.Uuid
  observedAt      DateTime
  ingestedAt      DateTime @default(now())
  temperatureC    Float?
  feelsLikeC      Float?
  rainMm          Float?
  rainProbability Float?
  windSpeedKmh    Float?
  windGustKmh     Float?
  windDirection   String?
  weatherCode     String?
  warningLevel    String?
  sourceName      String
  sourcePayload   Json?

  city               City                @relation(fields: [cityId], references: [id])
  dashboardSnapshots DashboardSnapshot[]
}

model AirQualitySnapshot {
  id            String   @id @default(uuid()) @db.Uuid
  cityId        String   @db.Uuid
  observedAt    DateTime
  ingestedAt    DateTime @default(now())
  aqiValue      Float?
  aqiLabel      String?
  pm25          Float?
  pm10          Float?
  no2           Float?
  o3            Float?
  so2           Float?
  mainPollutant String?
  trendLabel    String?
  sourceName    String
  sourcePayload Json?

  city               City                @relation(fields: [cityId], references: [id])
  dashboardSnapshots DashboardSnapshot[]
}

model WaterSnapshot {
  id            String   @id @default(uuid()) @db.Uuid
  cityId        String   @db.Uuid
  stationId     String?
  stationName   String?
  observedAt    DateTime
  ingestedAt    DateTime @default(now())
  waterLevelCm  Float?
  trendLabel    String?
  riskLabel     String?
  sourceName    String
  sourcePayload Json?

  city               City                @relation(fields: [cityId], references: [id])
  dashboardSnapshots DashboardSnapshot[]
}

model DashboardSnapshot {
  id          String   @id @default(uuid()) @db.Uuid
  cityId      String   @db.Uuid
  generatedAt DateTime @default(now())
  stateHash   String

  weatherSnapshotId    String? @db.Uuid
  airQualitySnapshotId String? @db.Uuid
  waterSnapshotId      String? @db.Uuid

  cycleComfortScore  Int?
  cycleComfortLabel  String?
  bestOutdoorWindow  String?
  worstOutdoorWindow String?
  summaryPayload     Json

  city               City                @relation(fields: [cityId], references: [id])
  weatherSnapshot    WeatherSnapshot?    @relation(fields: [weatherSnapshotId], references: [id])
  airQualitySnapshot AirQualitySnapshot? @relation(fields: [airQualitySnapshotId], references: [id])
  waterSnapshot      WaterSnapshot?      @relation(fields: [waterSnapshotId], references: [id])
  aiBriefings        AiBriefing[]
  qaInteractions     QaInteraction[]
}

model AiBriefing {
  id                  String    @id @default(uuid()) @db.Uuid
  cityId              String    @db.Uuid
  dashboardSnapshotId String    @db.Uuid
  stateHash           String
  modelName           String
  briefingText        String
  structuredBriefing  Json?
  generatedAt         DateTime  @default(now())
  expiresAt           DateTime?

  dashboardSnapshot DashboardSnapshot @relation(fields: [dashboardSnapshotId], references: [id])
}

model User {
  id               String    @id @default(uuid()) @db.Uuid
  externalProvider String?
  externalUserId   String?   @unique
  email            String?
  name             String?
  tier             String    @default("free")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastSeenAt       DateTime?

  qaInteractions QaInteraction[]
  usageQuotas    UsageQuota[]
}

model QaInteraction {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String?  @db.Uuid
  anonymousSessionId  String?
  cityId              String   @db.Uuid
  dashboardSnapshotId String?  @db.Uuid
  question            String
  normalizedIntent    String?
  answer              String
  answerMode          String
  usedModel           String?
  promptTokens        Int?
  completionTokens    Int?
  estimatedCostUsd    Decimal?
  cacheHit            Boolean  @default(false)
  createdAt           DateTime @default(now())

  user              User?              @relation(fields: [userId], references: [id])
  dashboardSnapshot DashboardSnapshot? @relation(fields: [dashboardSnapshotId], references: [id])
}

model UsageQuota {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String?  @db.Uuid
  anonymousSessionId String?
  periodStart        DateTime
  periodEnd          DateTime
  qaUsed             Int      @default(0)
  qaLimit            Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
}
